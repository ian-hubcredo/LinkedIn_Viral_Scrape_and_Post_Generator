      "parameters": {
        "jsCode": "const processedPosts = [];\n\n// Define the weights for your virality score\nconst weights = {\n  like: 1,\n  support: 2,\n  love: 2,\n  insight: 2,\n  celebrate: 2,\n  funny: 2,\n  comments: 5,\n  reposts: 10\n};\n\n// Loop through all incoming n8n items\nfor (const item of $input.all()) {\n  \n  // item.json IS the post object. (This was the mistake)\n  const post = item.json; \n\n  // --- Data Cleaning ---\n  // Skip any items that are missing stats or text\n  if (!post.impression_stats || !post.post_text) {\n    continue; // Skips this loop iteration and goes to the next post\n  }\n\n  // Get the stats object for easier access\n  const stats = post.impression_stats;\n\n  // --- 1. Flatten All Stats ---\n  // Use '|| 0' to set a default of 0 if a value is null\n  const like = stats.like || 0;\n  const support = stats.support || 0;\n  const love = stats.love || 0;\n  const insight = stats.insight || 0;\n  const celebrate = stats.celebrate || 0;\n  const funny = stats.funny || 0;\n  const total_reactions = stats.total_reactions || 0;\n  const comments = stats.comments || 0;\n  const reposts = stats.reposts || 0;\n\n  // --- 2. Calculate Simple Sum ---\n  // This is just a raw count of all interactions\n  const total_engagement_sum = total_reactions + comments + reposts;\n\n  // --- 3. Calculate Weighted Virality Score ---\n  const virality_score =\n    (like * weights.like) +\n    (support * weights.support) +\n    (love * weights.love) +\n    (insight * weights.insight) +\n    (celebrate * weights.celebrate) +\n    (funny * weights.funny) +\n    (comments * weights.comments) +\n    (reposts * weights.reposts);\n\n  // --- Create the new, flat object ---\n  const flatPost = {\n    post_text: post.post_text,\n    post_url: post.post_url,\n    keyword: post.keyword,\n    profile_url: post.profile_url,\n    \n    // Add all flattened stats\n    total_reactions: total_reactions,\n    like: like,\n    support: support,\n    love: love,\n    insight: insight,\n    celebrate: celebrate,\n    funny: funny,\n    comments: comments,\n    reposts: reposts,\n    \n    // Add your new calculated fields\n    total_engagement_sum: total_engagement_sum,\n    virality_score: virality_score\n  };\n  \n  processedPosts.push(flatPost);\n}\n\n// Return the new, clean list for the next node\nreturn processedPosts.map(post => ({ json: post }));"
      },
